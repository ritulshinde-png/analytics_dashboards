async function cuPost(path,body){
  const tok=getToken();if(!tok)throw new Error('no-token');
  const res=await fetch(`https://api.clickup.com/api/v2${path}`,{
    method:'POST',headers:{Authorization:tok,'Content-Type':'application/json'},body:JSON.stringify(body)
  });
  const d=await res.json();if(!res.ok)throw new Error(d.err||d.ECODE||`HTTP ${res.status}`);
  return d;
}
async function cuGet(path){
  const tok=getToken();if(!tok)throw new Error('no-token');
  const res=await fetch(`https://api.clickup.com/api/v2${path}`,{headers:{Authorization:tok}});
  const d=await res.json();if(!res.ok)throw new Error(d.err||`HTTP ${res.status}`);
  return d;
}
async function cuUpload(taskId,file){
  const fd=new FormData();fd.append('attachment',file,file.name);
  const res=await fetch(`https://api.clickup.com/api/v2/task/${taskId}/attachment`,{method:'POST',headers:{Authorization:getToken()},body:fd});
  if(!res.ok)console.warn('Attachment failed:',file.name);
}

// ── SUBMIT ────────────────────────────────────────────────────────────
async function doSubmit(){
  const feedback=document.getElementById('iFeedback').value.trim();
  const otherArea=document.getElementById('otherAreaInput').value.trim();

  if(!selectedUser){document.getElementById('userErr').classList.add('show');toast('Please select your name','err');return}
  if(platforms.size===0){document.getElementById('platErr').classList.add('show');toast('Select at least one platform','err');return}
  if(!selectedArea){document.getElementById('areaErr').classList.add('show');toast('Please select an area','err');return}
  if(selectedArea.id==='other'&&!otherArea){toast('Please describe the area','err');document.getElementById('otherAreaInput').focus();return}
  if(!feedback){toast('Please enter your feedback','err');document.getElementById('iFeedback').focus();return}
  if(!getToken()){toast('No API token set — please contact admin','err');return}

  localStorage.setItem(USER_KEY,JSON.stringify(selectedUser));
  showSaved(selectedUser);

  const btn=document.getElementById('submitBtn');
  btn.disabled=true;btn.classList.add('submitting');

  const platList = ['Android','iOS','BE','Web'].filter(p=>platforms.has(p));
  const areaName = selectedArea.id==='other' ? otherArea : selectedArea.name;
  const short    = feedback.length>80?feedback.slice(0,77)+'…':feedback;
  const isOther  = selectedArea.id==='other';
  const tags     = isOther ? [TAG_OTHERS] : [];

  const customFields=[
    {id:CF_REPORTED, value:selectedUser.name},
    {id:CF_DATE,     value:Date.now()},
  ];
  if(!isOther) customFields.push({id:CF_AREA, value:selectedArea.id});

  const createdTasks=[];

  try{
    const total = platList.length;

    for(let i=0;i<total;i++){
      const plat = platList[i];
      const title = `${plat}: ${short}`;
      const desc  = `${feedback}\n\n---\nPlatform: ${plat}\nArea: ${areaName}`;

      setProg(
        Math.round((i/total)*60)+5,
        total>1 ? `Creating task ${i+1} of ${total} (${plat})…` : 'Creating task…'
      );

      const task=await cuPost(`/list/${LIST_ID}/task`,{
        name:title,
        description:desc,
        status:'Open',
        notify_all:false,
        tags,
        custom_fields:customFields
      });
      createdTasks.push(task);

      // If "Other" area → add comment with typed area text
      if(isOther){
        try{
          await cuPost(`/task/${task.id}/comment`,{
            comment_text:`📍 Area (Other): ${otherArea}`,
            notify_all:false
          });
        }catch(e){console.warn('Other comment failed:',e)}
      }
    }

    // Upload attachments to ALL created tasks
    if(files.length>0){
      for(let ti=0;ti<createdTasks.length;ti++){
        for(let fIdx=0;fIdx<files.length;fIdx++){
          const overall = createdTasks.length*files.length;
          const done    = ti*files.length+fIdx;
          setProg(60+Math.round(done/overall*38), `Uploading ${files[fIdx].name}…`);
          await cuUpload(createdTasks[ti].id, files[fIdx]);
        }
      }
    }

    setProg(100);
    document.getElementById('formCard').style.display='none';
    const sc=document.getElementById('successCard');
    sc.classList.add('show');

    // If multiple tasks, link to the list view; if single, link directly
    document.getElementById('taskLink').href = createdTasks.length===1
      ? createdTasks[0].url
      : `https://app.clickup.com/43325543/v/li/${LIST_ID}`;

    // Update success message for multi-task
    sc.querySelector('p').innerHTML = createdTasks.length>1
      ? `Created <strong>${createdTasks.length} tasks</strong> (one per platform) with status <strong>Open</strong>.<br/>The team will triage them soon.`
      : `Added to the Dog-Fooding board with status <strong>Open</strong>.<br/>The team will triage it soon.`;

    loadLeaderboard();

  }catch(err){
    console.error(err);
    if(err.message==='no-token'||err.message.includes('401')||err.message.includes('403')){toast('Session error — please ask admin to refresh the API token','err')}
    else if(err.message.includes('fetch')||err.message.includes('Network')){toast('Network error — check connection','err')}
    else toast('Error: '+err.message,'err');
    btn.disabled=false;btn.classList.remove('submitting');setProg(0);
  }
}

