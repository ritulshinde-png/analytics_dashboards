<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Feedback Board — Demand Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#16140f;--ink2:#4a4640;--ink3:#9c9790;
  --paper:#f7f5f0;--paper2:#edeae3;--paper3:#e0ddd5;
  --line:#d8d3ca;--surface:#fff;--accent:#c84b2f;
  --r:10px;
  --shadow:0 1px 4px rgba(22,20,15,.08),0 4px 20px rgba(22,20,15,.05);
  --shadow-lg:0 8px 40px rgba(22,20,15,.14),0 2px 8px rgba(22,20,15,.07);
}
body{font-family:'Instrument Sans',system-ui,sans-serif;background:var(--paper);color:var(--ink);min-height:100vh;-webkit-font-smoothing:antialiased}

/* SETUP BANNER */
#setupBanner{background:#fffbeb;border-bottom:1px solid #fde68a;padding:16px 24px;display:flex;align-items:flex-start;gap:12px}
#setupBanner.hidden{display:none}
.sb-icon{font-size:18px;flex-shrink:0;margin-top:2px}
.sb-body{flex:1}.sb-body strong{font-size:14px;display:block;margin-bottom:5px;color:#92400e}
.sb-body p{font-size:13px;color:#78350f;line-height:1.55}.sb-body a{color:#92400e;font-weight:600}
.sb-row{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;align-items:center}
#tokenInput{flex:1;min-width:200px;padding:8px 12px;border:1.5px solid #fde68a;border-radius:8px;background:#fffbeb;font-family:monospace;font-size:13px;color:#78350f;outline:none}
.sb-save{padding:8px 16px;background:#92400e;color:#fff;border:none;border-radius:8px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap}
.sb-close{background:none;border:none;cursor:pointer;font-size:20px;color:#92400e;flex-shrink:0;padding:0 2px;line-height:1;align-self:flex-start}

/* PIN MODAL */
#pinModal{position:fixed;inset:0;background:rgba(22,20,15,.55);z-index:500;display:none;align-items:center;justify-content:center;padding:24px}
#pinModal.show{display:flex}
.pin-card{background:var(--surface);border-radius:16px;padding:32px 28px;width:100%;max-width:360px;box-shadow:var(--shadow-lg);text-align:center}
.pin-card h3{font-family:'Instrument Serif',serif;font-size:22px;font-weight:400;margin-bottom:8px}
.pin-card p{font-size:13px;color:var(--ink2);margin-bottom:20px;line-height:1.55}
#pinInput{width:100%;padding:11px 14px;border:1.5px solid var(--line);border-radius:var(--r);font-family:monospace;font-size:22px;letter-spacing:.25em;text-align:center;outline:none;background:var(--paper);color:var(--ink);margin-bottom:4px}
#pinInput:focus{border-color:var(--ink)}
#pinInput.wrong{border-color:#dc2626;animation:shake .35s ease}
.pin-err{font-size:12px;color:#dc2626;margin-top:4px;margin-bottom:10px;min-height:18px}
.pin-btns{display:flex;gap:8px;margin-top:10px}
.pin-cancel{flex:1;padding:10px;background:var(--paper2);border:1px solid var(--line);border-radius:var(--r);font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;color:var(--ink2)}
.pin-go{flex:2;padding:10px;background:var(--ink);color:#fff;border:none;border-radius:var(--r);font-family:inherit;font-size:14px;font-weight:600;cursor:pointer}

/* HEADER */
header{background:var(--ink);color:var(--paper);padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px;font-size:15px;font-weight:600;letter-spacing:-.01em}
.logo-mark{width:24px;height:24px;background:var(--accent);border-radius:6px;display:flex;align-items:center;justify-content:center}
.logo-mark svg{width:12px;height:12px;fill:white}
.hdr-right{display:flex;align-items:center;gap:10px}
.hdr-badge{font-size:12px;color:#9c9790;background:rgba(255,255,255,.08);border-radius:20px;padding:3px 10px}
.hdr-settings{background:none;border:none;cursor:pointer;color:#9c9790;font-size:15px;padding:5px;border-radius:6px;transition:color .15s;line-height:1}
.hdr-settings:hover{color:#f7f5f0}

/* MAIN */
main{max-width:680px;margin:0 auto;padding:40px 24px 80px}

/* HERO */
.hero{margin-bottom:32px;animation:fadeUp .45s ease both}
.hero h1{font-family:'Instrument Serif',serif;font-size:30px;font-weight:400;letter-spacing:-.02em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:8px}
.hero h1 em{font-style:italic;color:var(--accent)}
.hero p{font-size:14px;color:var(--ink2);line-height:1.6}

/* LAYOUT: form full width, leaderboard below */
.page-grid{display:flex;flex-direction:column;gap:24px}

/* CARD */
.card{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:28px 28px 24px;box-shadow:var(--shadow)}
.form-card{animation:fadeUp .45s .08s ease both}
.field{margin-bottom:20px}
.divider{height:1px;background:var(--line);margin:22px 0}
label{display:block;font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--ink2);margin-bottom:7px}
label .opt{font-weight:400;text-transform:none;letter-spacing:0;color:var(--ink3);font-size:12px}
textarea,input[type=text]{width:100%;padding:11px 14px;border:1.5px solid var(--line);border-radius:var(--r);font-family:inherit;font-size:15px;color:var(--ink);background:var(--paper);outline:none;transition:border-color .15s,background .15s}
textarea{resize:vertical;line-height:1.6}
textarea:focus,input[type=text]:focus{border-color:var(--ink);background:var(--surface)}
textarea::placeholder,input[type=text]::placeholder{color:var(--ink3)}

/* SELECT */
.select-wrap{position:relative}
.select-display{width:100%;padding:11px 40px 11px 14px;border:1.5px solid var(--line);border-radius:var(--r);font-family:inherit;font-size:15px;color:var(--ink);background:var(--paper);cursor:pointer;display:flex;align-items:center;gap:10px;transition:border-color .15s,background .15s;user-select:none}
.select-display:hover,.select-display.open{border-color:var(--ink);background:var(--surface)}
.select-display .ph{color:var(--ink3)}
.sel-arrow{position:absolute;right:12px;top:50%;transform:translateY(-50%);pointer-events:none;color:var(--ink3);font-size:11px;transition:transform .15s}
.select-display.open+.sel-arrow{transform:translateY(-50%) rotate(180deg)}
.sel-av{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;color:white}
.sel-drop{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow-lg);z-index:200;max-height:240px;overflow-y:auto;display:none}
.sel-drop.open{display:block}
.sel-search{padding:10px 12px;border:none;border-bottom:1px solid var(--line);width:100%;font-family:inherit;font-size:14px;color:var(--ink);background:var(--surface);outline:none}
.sel-search::placeholder{color:var(--ink3)}
.sel-opt{display:flex;align-items:center;gap:10px;padding:9px 14px;cursor:pointer;font-size:14px;color:var(--ink);transition:background .1s}
.sel-opt:hover{background:var(--paper2)}
.sel-opt .on{flex:1}
.sel-check{font-size:13px;color:var(--accent);display:none}
.sel-opt.selected .sel-check{display:block}
.saved-badge{display:none;align-items:center;gap:8px;padding:8px 12px;background:var(--paper2);border:1px solid var(--line);border-radius:20px;font-size:13px;color:var(--ink)}
.saved-badge.show{display:inline-flex}
.saved-av{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600;color:white;flex-shrink:0}
.change-btn{background:none;border:none;cursor:pointer;font-size:11px;color:var(--ink3);text-decoration:underline;padding:0;margin-left:2px}
.change-btn:hover{color:var(--accent)}

/* CHIPS */
.chip-group{display:flex;gap:8px;flex-wrap:wrap}
.chip{padding:8px 14px;border:1.5px solid var(--line);border-radius:30px;font-size:13px;font-weight:500;cursor:pointer;background:var(--paper);color:var(--ink2);transition:border-color .15s,background .15s,color .15s;user-select:none}
.chip:hover{border-color:var(--ink2);color:var(--ink)}
.chip.active{background:var(--ink);color:#fff;border-color:var(--ink)}
.area-chip{padding:8px 14px;border:1.5px solid var(--line);border-radius:30px;font-size:13px;font-weight:500;cursor:pointer;background:var(--paper);color:var(--ink2);transition:border-color .15s,background .15s,color .15s;user-select:none}
.area-chip:hover{border-color:var(--ink2);color:var(--ink)}
.area-chip.active{color:#fff;border-color:transparent}
.area-chip.other-chip{border-style:dashed}
.area-chip.other-chip.active{background:var(--ink);border-style:solid;border-color:var(--ink)}
.other-input-wrap{margin-top:10px;display:none}
.other-input-wrap.show{display:block}
.field-err{font-size:12px;color:#dc2626;margin-top:6px;display:none}
.field-err.show{display:block}

/* DROPZONE */
.dropzone{border:1.5px dashed var(--line);border-radius:var(--r);padding:26px 20px;text-align:center;cursor:pointer;background:var(--paper);transition:border-color .15s,background .15s;position:relative}
.dropzone:hover,.dropzone.over{border-color:var(--accent);background:#fdf5f3}
.dropzone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.dz-icon{font-size:26px;display:block;margin-bottom:7px}
.dz-label{font-size:14px;font-weight:500;color:var(--ink2)}
.dz-hint{font-size:12px;color:var(--ink3);margin-top:3px}
.file-list{margin-top:10px;display:flex;flex-direction:column;gap:7px}
.file-chip{display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--paper2);border:1px solid var(--line);border-radius:8px}
.file-thumb{width:34px;height:34px;border-radius:6px;flex-shrink:0;background:var(--paper3);overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:16px}
.file-thumb img{width:100%;height:100%;object-fit:cover}
.file-name{flex:1;font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.file-size{font-size:11px;color:var(--ink3);flex-shrink:0}
.file-del{background:none;border:none;cursor:pointer;color:var(--ink3);font-size:18px;line-height:1;padding:0 3px;flex-shrink:0}
.file-del:hover{color:var(--accent)}
.prog-wrap{margin-top:10px;display:none}.prog-wrap.show{display:block}
.prog-track{height:3px;background:var(--paper3);border-radius:2px;overflow:hidden}
.prog-bar{height:100%;background:var(--accent);border-radius:2px;width:0%;transition:width .3s ease}
.prog-text{font-size:12px;color:var(--ink3);margin-top:5px;text-align:center}

/* SUBMIT */
.submit-btn{width:100%;padding:13px 20px;background:var(--ink);color:white;border:none;border-radius:var(--r);font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;transition:background .15s,transform .1s;display:flex;align-items:center;justify-content:center;gap:9px;margin-top:6px}
.submit-btn:hover:not(:disabled){background:#2a2820}
.submit-btn:active:not(:disabled){transform:scale(.99)}
.submit-btn:disabled{opacity:.5;cursor:not-allowed}
.spinner{width:15px;height:15px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:none}
.submitting .spinner{display:block}.submitting .btn-label{display:none}
.kbd-hint{text-align:center;font-size:12px;color:var(--ink3);margin-top:8px}
kbd{background:var(--paper2);border:1px solid var(--line);padding:1px 6px;border-radius:4px;font-size:11px}

/* SUCCESS */
.success-card{display:none;animation:fadeUp .4s ease both;text-align:center;padding:40px 28px}
.success-card.show{display:block}
.s-ring{width:56px;height:56px;background:#d5f2e0;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-size:26px}
.success-card h2{font-family:'Instrument Serif',serif;font-size:26px;font-weight:400;margin-bottom:10px}
.success-card p{font-size:14px;color:var(--ink2);line-height:1.65;margin-bottom:24px}
.task-link{display:inline-flex;align-items:center;gap:7px;padding:10px 18px;border:1.5px solid var(--line);border-radius:8px;font-size:13px;font-weight:500;color:var(--ink);text-decoration:none;background:var(--paper);transition:border-color .15s;margin-bottom:14px}
.task-link:hover{border-color:var(--ink)}
.reset-btn{display:block;width:100%;padding:12px;margin-top:4px;background:var(--paper2);border:1px solid var(--line);border-radius:var(--r);font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;color:var(--ink);transition:background .15s}
.reset-btn:hover{background:var(--paper3)}

/* ── LEADERBOARD ── */
.lb-card{animation:fadeUp .45s .15s ease both}
.lb-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap}
.lb-title{font-family:'Instrument Serif',serif;font-size:20px;font-weight:400}
.lb-refresh{background:none;border:1px solid var(--line);border-radius:8px;padding:5px 10px;font-family:inherit;font-size:12px;color:var(--ink2);cursor:pointer;display:flex;align-items:center;gap:5px;transition:border-color .15s}
.lb-refresh:hover{border-color:var(--ink)}
.lb-refresh.spinning svg{animation:spin .7s linear infinite}

/* Date filter */
.lb-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.date-pill{padding:6px 12px;border:1.5px solid var(--line);border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;background:var(--paper);color:var(--ink2);transition:border-color .15s,background .15s,color .15s;user-select:none}
.date-pill:hover{border-color:var(--ink2)}
.date-pill.active{background:var(--ink);color:#fff;border-color:var(--ink)}

/* Table */
.lb-table-wrap{overflow-x:auto}
.lb-table{width:100%;border-collapse:collapse;font-size:13px}
.lb-table th{font-size:11px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--ink3);padding:8px 10px;text-align:left;border-bottom:1px solid var(--line);white-space:nowrap}
.lb-table td{padding:10px 10px;border-bottom:1px solid var(--paper2);vertical-align:middle}
.lb-table tr:last-child td{border-bottom:none}
.lb-table tr:hover td{background:var(--paper)}
.lb-name{display:flex;align-items:center;gap:8px;font-weight:500}
.lb-av{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:white;flex-shrink:0}
.lb-num{text-align:center;font-weight:600;color:var(--ink)}
.lb-num-sm{text-align:center;color:var(--ink2)}
.lb-resolved{text-align:center;color:#1a6b3c;font-weight:500}
.rank-1{color:#d4a520;font-weight:700}
.rank-2{color:#9c9790;font-weight:600}
.rank-3{color:#c05e20;font-weight:600}
.lb-empty{text-align:center;padding:32px;color:var(--ink3);font-size:14px}
.lb-loading{text-align:center;padding:32px;color:var(--ink3);font-size:13px;display:flex;align-items:center;justify-content:center;gap:8px}
.lb-loading-spin{width:16px;height:16px;border:2px solid var(--line);border-top-color:var(--ink3);border-radius:50%;animation:spin .7s linear infinite}

/* TOASTS */
.toasts{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:999;display:flex;flex-direction:column;gap:8px;align-items:center;pointer-events:none}
.toast{padding:11px 20px;border-radius:30px;font-size:14px;font-weight:500;box-shadow:var(--shadow-lg);opacity:0;transform:translateY(10px);transition:opacity .22s,transform .22s;max-width:400px;text-align:center;pointer-events:auto}
.toast.in{opacity:1;transform:translateY(0)}
.toast.ok{background:var(--ink);color:#fff}
.toast.err{background:#fef2f2;color:#9b1c1c;border:1px solid #fecaca}

@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
</style>
</head>
<body>

<!-- SETUP BANNER -->
<div id="setupBanner" class="hidden">
  <span class="sb-icon">🔑</span>
  <div class="sb-body">
    <strong>Admin setup: ClickUp API token</strong>
    <p>Go to <a href="https://app.clickup.com/settings/apps" target="_blank">ClickUp → Settings → Apps → API Token</a>. Stored only in this browser.</p>
    <div class="sb-row">
      <input type="text" id="tokenInput" placeholder="pk_XXXXXXXXXXXXXXXXXX" spellcheck="false"/>
      <button class="sb-save" onclick="saveToken()">Save →</button>
    </div>
  </div>
  <button class="sb-close" onclick="hideBanner()">×</button>
</div>

<!-- PIN MODAL -->
<div id="pinModal">
  <div class="pin-card">
    <h3>Admin access</h3>
    <p>Enter the admin PIN to access token settings.</p>
    <input type="password" id="pinInput" placeholder="····" maxlength="6"
      oninput="clearPinErr()" onkeydown="if(event.key==='Enter')checkPin()"/>
    <div class="pin-err" id="pinErr"></div>
    <div class="pin-btns">
      <button class="pin-cancel" onclick="closePinModal()">Cancel</button>
      <button class="pin-go" onclick="checkPin()">Unlock →</button>
    </div>
  </div>
</div>

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-mark">
      <svg viewBox="0 0 14 14"><rect x="1" y="2" width="12" height="1.5" rx=".75"/><rect x="1" y="6" width="12" height="1.5" rx=".75"/><rect x="1" y="10" width="7" height="1.5" rx=".75"/></svg>
    </div>
    Dog-Fooding Feedback
  </div>
  <div class="hdr-right">
    <span class="hdr-badge">Demand Platform</span>
    <button class="hdr-settings" onclick="requestSettings()" title="Admin settings">⚙</button>
  </div>
</header>

<main>
  <div class="hero">
    <h1>Found something <em>worth fixing?</em></h1>
    <p>Submit feedback to improve our App. Add screenshots or recordings for more context.</p>
  </div>

  <div class="page-grid">

    <!-- ── FORM ── -->
    <div class="card form-card" id="formCard">

        <div class="field">
          <label>Who are you?</label>
          <div class="saved-badge" id="savedBadge">
            <div class="saved-av" id="savedAv"></div>
            <span id="savedName"></span>
            <button class="change-btn" onclick="changeUser()">change</button>
          </div>
          <div id="pickerWrap">
            <div class="select-wrap" id="selWrap">
              <div class="select-display" id="selDisplay" onclick="toggleDrop()">
                <span class="ph">Select your name…</span>
              </div>
              <span class="sel-arrow">▾</span>
              <div class="sel-drop" id="selDrop">
                <input class="sel-search" id="selSearch" placeholder="Search name…" oninput="filterOpts()" onclick="event.stopPropagation()"/>
                <div id="optsList"></div>
              </div>
            </div>
            <div class="field-err" id="userErr">Please select your name.</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Which platforms issue are you reporting?</label>
          <div class="chip-group">
            <div class="chip" data-val="Android" onclick="togglePlat(this)">Android</div>
            <div class="chip" data-val="iOS" onclick="togglePlat(this)">iOS</div>
            <div class="chip" data-val="BE" onclick="togglePlat(this)">BE</div>
            <div class="chip" data-val="Web" onclick="togglePlat(this)">Web</div>
          </div>
          <div class="field-err" id="platErr">Please select at least one platform.</div>
        </div>

        <div class="field">
          <label>Which product area does this issue belong to?</label>
          <div class="chip-group" id="areaGroup"></div>
          <div class="other-input-wrap" id="otherWrap">
            <input type="text" id="otherAreaInput" placeholder="Describe the area…" maxlength="80"/>
          </div>
          <div class="field-err" id="areaErr">Please select an area.</div>
        </div>

        <div class="field">
          <label>Please type the issue you want to report <span class="opt">(required)</span></label>
          <textarea id="iFeedback" rows="4"
            placeholder="Describe the issue — what you saw, what you expected, and steps to reproduce…"></textarea>
        </div>

        <div class="field">
          <label>Add screenshots/videos of the reported issue <span class="opt">(optional)</span></label>
          <div class="dropzone" id="dz">
            <input type="file" id="fi" multiple accept="image/*,video/*"/>
            <span class="dz-icon">📎</span>
            <div class="dz-label">Click to attach or drag &amp; drop</div>
            <div class="dz-hint">JPG · PNG · GIF · MP4 · MOV · WebM</div>
          </div>
          <div class="file-list" id="fileList"></div>
          <div class="prog-wrap" id="pw">
            <div class="prog-track"><div class="prog-bar" id="pb"></div></div>
            <div class="prog-text" id="pt"></div>
          </div>
        </div>

        <button class="submit-btn" id="submitBtn" onclick="doSubmit()">
          <div class="spinner"></div>
          <span class="btn-label">Submit to ClickUp →</span>
        </button>
        <p class="kbd-hint">or <kbd>⌘ Enter</kbd> / <kbd>Ctrl Enter</kbd></p>
      </div>

      <div class="card success-card" id="successCard">
        <div class="s-ring">✓</div>
        <h2>Feedback submitted!</h2>
        <p>Added to the Dog-Fooding board with status <strong>Open</strong>.<br/>The team will triage it soon.</p>
        <a id="taskLink" href="#" target="_blank" rel="noopener" class="task-link">↗ View task in ClickUp</a>
