// ── LEADERBOARD ───────────────────────────────────────────────────────

async function fetchAllTasks(){
  // Paginate through all tasks in the list
  let page=0, tasks=[];
  while(true){
    const data=await cuGet(`/list/${LIST_ID}/task?include_closed=true&subtasks=false&page=${page}&fields=name,status,custom_fields,date_created`);
    const batch=data.tasks||[];
    tasks=[...tasks,...batch];
    if(batch.length<100)break;
    page++;
  }
  return tasks;
}

function getReportedBy(task){
  const cf=task.custom_fields?.find(f=>f.id===CF_REPORTED);
  return cf?.value||'';
}

function getReportedOn(task){
  const cf=task.custom_fields?.find(f=>f.id===CF_DATE);
  return cf?.value ? Number(cf.value) : Number(task.date_created);
}

function toDateKey(ts){
  const d=new Date(ts);
  return d.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
}

async function loadLeaderboard(){
  if(!getToken()){renderLbEmpty('Add your API token to see the leaderboard.');return}
  const btn=document.getElementById('refreshBtn');
  btn.classList.add('spinning');
  document.getElementById('lbBody').innerHTML=`<div class="lb-loading"><div class="lb-loading-spin"></div> Loading…</div>`;
  try{
    allTasks=await fetchAllTasks();
    buildDateFilters();
    renderLeaderboard();
  }catch(e){
    document.getElementById('lbBody').innerHTML=`<div class="lb-empty">Failed to load: ${e.message}</div>`;
  }finally{
    btn.classList.remove('spinning');
  }
}

function buildDateFilters(){
  const dates=new Set();
  allTasks.forEach(t=>{
    const ts=getReportedOn(t);
    if(ts)dates.add(toDateKey(ts));
  });
  const sorted=[...dates].sort((a,b)=>new Date(b)-new Date(a));

  const container=document.getElementById('lbFilters');
  container.innerHTML='<div class="date-pill active" data-date="all" onclick="filterDate(this)">All time</div>';
  sorted.forEach(d=>{
    const el=document.createElement('div');
    el.className='date-pill';el.dataset.date=d;
    el.textContent=d;el.onclick=()=>filterDate(el);
    container.appendChild(el);
  });
  activeDateFilter='all';
}

function filterDate(el){
  document.querySelectorAll('.date-pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  activeDateFilter=el.dataset.date;
  renderLeaderboard();
}

function renderLeaderboard(){
  // Filter tasks to exclude test tasks and empty reporter names
  const validTasks=allTasks.filter(t=>{
    const name=t.name||'';
    if(name.startsWith('🧪'))return false; // test tasks
    const reporter=getReportedBy(t);
    return reporter&&reporter.trim().length>0;
  });

  // Build global stats per reporter (all time)
  const globalStats={};
  validTasks.forEach(t=>{
    const reporter=getReportedBy(t).trim();
    if(!reporter)return;
    if(!globalStats[reporter])globalStats[reporter]={total:0,resolved:0};
    globalStats[reporter].total++;
    const st=(t.status?.status||t.status||'').toLowerCase();
    if(st==='resolved'||st==='done')globalStats[reporter].resolved++;
  });

  // Filter tasks by selected date for the "on this date" count
  const dateFiltered=activeDateFilter==='all'
    ? validTasks
    : validTasks.filter(t=>toDateKey(getReportedOn(t))===activeDateFilter);

  // Build date-filtered count per reporter
  const dateStats={};
  dateFiltered.forEach(t=>{
    const reporter=getReportedBy(t).trim();
    if(!reporter)return;
    dateStats[reporter]=(dateStats[reporter]||0)+1;
  });

  // Merge into rows — only reporters who have entries globally
  const rows=Object.entries(globalStats).map(([name,g])=>({
    name,
    dateCount:dateStats[name]||0,
    total:g.total,
    resolved:g.resolved
  }));

  // Sort by dateCount desc, then total desc
  rows.sort((a,b)=>b.dateCount-a.dateCount||b.total-a.total);

  if(rows.length===0){
    renderLbEmpty('No feedback submitted yet.');
    return;
  }

  const colLabel=activeDateFilter==='all'?'All time':'On '+activeDateFilter;

  let html=`
    <div class="lb-table-wrap">
    <table class="lb-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th style="text-align:center">${colLabel}</th>
          <th style="text-align:center">Total</th>
          <th style="text-align:center">Resolved</th>
        </tr>
      </thead>
      <tbody>
  `;

  rows.forEach((r,i)=>{
    const rank=i+1;
    const rankClass=rank===1?'rank-1':rank===2?'rank-2':rank===3?'rank-3':'';
    const color=aC(r.name.split('').reduce((a,c)=>a+c.charCodeAt(0),0));
    const initials=aI(r.name);
    html+=`
      <tr>
        <td><span class="${rankClass}" style="font-size:13px">${rank}</span></td>
        <td>
          <div class="lb-name">
            <div class="lb-av" style="background:${color}">${initials}</div>
            ${r.name}
          </div>
        </td>
        <td class="lb-num">${r.dateCount>0?r.dateCount:'—'}</td>
        <td class="lb-num-sm">${r.total}</td>
        <td class="lb-resolved">${r.resolved>0?r.resolved:'—'}</td>
      </tr>
    `;
  });

  html+=`</tbody></table></div>`;
  document.getElementById('lbBody').innerHTML=html;
}

function renderLbEmpty(msg){
  document.getElementById('lbBody').innerHTML=`<div class="lb-empty">${msg}</div>`;
}

document.addEventListener('keydown',e=>{
  if((e.metaKey||e.ctrlKey)&&e.key==='Enter')doSubmit();
  if(e.key==='Escape'){closePinModal();hideBanner();closeDrop()}
});
</script>
</body>
</html>
